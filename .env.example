# ── Obsidian Vault ────────────────────────────────────────────────────────────
# Obsidian Vault 的绝对路径（指向存放球队档案的 Vault 根目录）
ARES_VAULT_PATH=/Users/liumingwei/Library/Mobile Documents/com~apple~CloudDocs/Ares-Matrix-DB/

# ── LLM 路由配置 ──────────────────────────────────────────────────────────────
# Provider 选择: openai | gemini | openai_compat
# openai        → 使用官方 OpenAI API
# gemini        → 使用 Google Gemini 原生 SDK
# openai_compat → 任意 OpenAI 兼容端点（第三方中转、one-api、openrouter 等）
ARES_LLM_PROVIDER=openai

# 模型名称（留空则使用各 provider 默认值）
# openai 默认:        gpt-4o
# gemini 默认:        gemini-1.5-pro
# openai_compat 默认: gpt-4o（可改为中转平台支持的任意模型）
ARES_LLM_MODEL=

# 通用 API Key（优先级高于各 provider 专属 key）
# 使用第三方中转时填写中转平台的 key
ARES_LLM_API_KEY=

# 自定义 API base URL（openai_compat 必填；openai 可选覆盖为代理地址）
# 示例 - 硅基流动:   https://api.siliconflow.cn/v1
# 示例 - OpenRouter: https://openrouter.ai/api/v1
# 示例 - one-api:    https://your-one-api.com/v1
# 示例 - Gemini兼容: https://generativelanguage.googleapis.com/v1beta/openai/
ARES_LLM_BASE_URL=

# ── Provider 专属 Key（各 provider 回退 key，优先使用 ARES_LLM_API_KEY）─────
# OpenAI 官方 Key
OPENAI_API_KEY=sk-...

# Google Gemini Key（ARES_LLM_PROVIDER=gemini 时使用）
GEMINI_API_KEY=

# ── 其他集成 ─────────────────────────────────────────────────────────────────
# Discord Webhook URL（用于投递审计结果到 #football-command 频道）
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
